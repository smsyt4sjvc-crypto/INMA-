# Copy this file to `.env` and fill in your PAPER keys. NEVER commit the real .env (.gitignore blocks it).
# Get keys from the Alpaca dashboard in PAPER mode -> API Keys -> Generate. Secret shown once.

ALPACA_API_KEY_ID=PASTE_YOUR_PAPER_KEY_ID
ALPACA_API_SECRET_KEY=PASTE_YOUR_PAPER_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Live comes later, ring-fenced, human-in-the-loop. Do NOT put live keys here until the paper record earns it.
